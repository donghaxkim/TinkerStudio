{
  "name": "tinker",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "validate:schema": "pnpm --filter @tinker/project-schema validate:sample",
    "generate:manual-demo": "pnpm --filter @tinker/demo-assembly generate:manual-demo",
    "generate:local-job": "pnpm --filter @tinker/demo-assembly generate:local-job",
    "generate:ai-url-fixture-job": "pnpm --filter @tinker/demo-assembly generate:ai-url-fixture-job",
    "generate:ai-url-job": "pnpm --filter @tinker/demo-assembly generate:ai-url-job"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}

{
  "name": "@tinker/rendering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "pnpm --filter @tinker/project-schema build && pnpm --filter @tinker/motion build && tsc -p tsconfig.json",
    "typecheck": "pnpm --filter @tinker/project-schema build && pnpm --filter @tinker/motion build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "render:sample": "pnpm build && node dist/cli/renderSampleProject.js"
  },
  "dependencies": {
    "@tinker/motion": "workspace:*",
    "@tinker/project-schema": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

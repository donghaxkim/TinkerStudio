{
  "name": "@tinker/project-schema",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts",
      "default": "./src/node.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate:sample": "tsx src/sampleProject.ts"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "tsx": "^4.21.0",
    "vitest": "^4.0.15"
  }
}
